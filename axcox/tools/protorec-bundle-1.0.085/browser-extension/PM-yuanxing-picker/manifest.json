{
  "manifest_version": 3,
  "name": "PM原型拾取器",
  "version": "1.0.85",
  "version_name": "1.0.085",
  "description": "辅助PM还原页面给AI，进行二次原型编辑",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "http://localhost/*"
  ],
  "icons": {
    "16": "assets/logo-16.png",
    "32": "assets/logo-32.png",
    "48": "assets/logo-48.png",
    "128": "assets/logo-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/logo-16.png",
      "32": "assets/logo-32.png",
      "48": "assets/logo-48.png",
      "128": "assets/logo-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
