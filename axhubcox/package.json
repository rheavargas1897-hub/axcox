{
  "name": "@axhub/make",
  "version": "0.5.3-beta.0",
  "description": "Axhub Make management server and admin UI",
  "private": true,
  "type": "module",
  "bin": {
    "axhub-make": "./bin/cli.mjs",
    "make": "./bin/cli.mjs",
    "make-server": "./bin/cli.mjs"
  },
  "files": [
    "bin",
    "scripts",
    "src/server",
    "dist/admin",
    "vendor",
    "package.json"
  ],
  "scripts": {
    "vendor:sync": "node scripts/sync-vendor-package.mjs",
    "dev": "pnpm --filter @axhub/make-client dev",
    "server:dev": "pnpm vendor:sync && tsx watch --ignore './src/index/**' --ignore './dist/**' --ignore './src/dev-template/**' --ignore './src/spec-template/**' --ignore './src/canvas-template/**' --ignore './src/html-template/**' --ignore './*.timestamp-*' src/server/cli.ts -- ./client --dev",
    "make-server:dev": "pnpm server:dev",
    "admin:dev": "pnpm vendor:sync && vite",
    "build": "pnpm vendor:sync && vite build && pnpm --filter @axhub/make-client build",
    "admin:build": "pnpm vendor:sync && vite build",
    "server:build": "pnpm vendor:sync && tsc --noEmit -p tsconfig.node.json",
    "client:typecheck": "pnpm --filter @axhub/make-client typecheck",
    "client:build": "pnpm --filter @axhub/make-client build",
    "preview": "vite preview",
    "test": "pnpm vendor:sync && AXHUB_MAKE_COVERAGE_SCOPE=all vitest run --coverage",
    "test:watch": "pnpm vendor:sync && vitest",
    "test:coverage": "pnpm vendor:sync && AXHUB_MAKE_COVERAGE_SCOPE=all vitest run --coverage",
    "server:test": "pnpm vendor:sync && AXHUB_MAKE_COVERAGE_SCOPE=server vitest run --coverage src/server/__tests__",
    "server:test:watch": "pnpm vendor:sync && vitest src/server/__tests__",
    "server:test:coverage": "pnpm vendor:sync && AXHUB_MAKE_COVERAGE_SCOPE=server vitest run --coverage src/server/__tests__",
    "server:test:api": "pnpm vendor:sync && AXHUB_MAKE_COVERAGE_SCOPE=server vitest run --coverage src/server/__tests__/projects-*-api.test.ts src/server/__tests__/http.test.ts",
    "server:test:runtime": "pnpm vendor:sync && AXHUB_MAKE_COVERAGE_SCOPE=server vitest run --coverage src/server/__tests__/runtimeProxy.test.ts src/server/__tests__/quickEditRuntimeApi.test.ts src/server/__tests__/assistant-runtime-api.test.ts src/server/__tests__/ide-open-api.test.ts",
    "server:test:exports": "pnpm vendor:sync && AXHUB_MAKE_COVERAGE_SCOPE=server vitest run --coverage src/server/__tests__/export-make-api.test.ts src/server/__tests__/projects-export-bridge-api.test.ts",
    "opencode-bridge:test": "pnpm vendor:sync && vitest run src/index/hooks/openCodeBridgeContext.test.ts src/index/hooks/useAxhubBridge.test.ts src/index/components/sidebar/OpenInDropdown.test.ts src/index/components/sidebar/ContentPanel.test.ts src/index/components/sidebar/IconNavigation.test.ts src/index/app/IndexPage.test.ts src/server/__tests__/opencode-bridge-regression.test.ts src/server/__tests__/adminStatic.test.ts",
    "release:make:prepare": "node scripts/release-make.mjs --prepare-only",
    "release:make:test-local": "node scripts/release-make.mjs --test-local",
    "release:make:dry-run": "node scripts/release-make.mjs --dry-run",
    "release:make:npm:latest": "node scripts/release-make.mjs --skip-github --npm-tag latest",
    "release:make:npm:beta": "node scripts/release-make.mjs --skip-github --npm-tag beta",
    "release:make-client-template:prepare": "node scripts/release-make.mjs --template-only --prepare-only",
    "release:make-client-template": "node scripts/release-make.mjs --template-only",
    "release:make:mirror:gitee": "node scripts/release-make-mirror-gitee.mjs",
    "release:make": "node scripts/release-make.mjs"
  },
