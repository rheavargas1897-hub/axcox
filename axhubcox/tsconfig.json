{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@ant-design/cssinjs": ["./node_modules/@ant-design/cssinjs"],
      "@axhub/excalidraw": ["./vendor/axhub-excalidraw/dist/types/excalidraw/index.d.ts"],
      "@axhub/excalidraw/*": ["./vendor/axhub-excalidraw/dist/types/excalidraw/*.d.ts"],
      "axhub-export-core": ["./vendor/axhub-export-core/dist/index.d.ts"],
      "axhub-genie-editor": ["./vendor/axhub-genie-editor/src/index.ts"],
      "tiptap-editor": ["./vendor/tiptap-editor/dist/index.d.ts"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
