  "compilerOptions": {
    "baseUrl": "..",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@ant-design/cssinjs": [
        "./node_modules/@ant-design/cssinjs"
      ],
      "@axhub/excalidraw": [
        "./vendor/axhub-excalidraw/dist/types/excalidraw/index.d.ts"
